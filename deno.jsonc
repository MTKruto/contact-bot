{
  "lock": true,
  "fmt": {
    "lineWidth": 120
  },
  "imports": {
    "@mtkruto/mtkruto": "jsr:@mtkruto/mtkruto@^0.161.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.7",
    "envalid/": "https://deno.land/x/envalid@0.1.2/"
  },
  "tasks": {
    // Note that the `--unstable` flag is needed for Deno KV. MTKruto does not require it.
    "start": "deno run --allow-env --allow-net --allow-read --unstable main.ts"
  }
}
